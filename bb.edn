{:paths ["src" "test" "bench"]
 :tasks
 {test     {:doc  "Run the test suite against both stores"
            :task (do (require '[memgraph.run-tests])
                      ((resolve 'memgraph.run-tests/-main)))}
  bench    {:doc  "Run the memory benchmark (bb bench = deterministic mechanics; bb bench llm = LLM quality layer)"
            :task (apply (requiring-resolve 'memgraph.bench/-main) *command-line-args*)}
  memgraph {:doc  "Run the memgraph CLI (bb run memgraph -- <args>)"
            :task (apply (requiring-resolve 'memgraph.cli/-main) *command-line-args*)}}}
